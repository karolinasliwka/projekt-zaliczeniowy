<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Kalkulator" Height="520" Width="360"
        MinHeight="480" MinWidth="320"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown">

    <!-- Wspólny styl dla wszystkich przycisków kalkulatora -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#707070" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styl dla przycisków operatorów (wyróżnione kolorem) -->
        <Style x:Key="OpButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF8C00" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- wyświetlacz -->
            <RowDefinition Height="*" />
            <!-- klawiatura -->
        </Grid.RowDefinitions>

        <!-- WYŚWIETLACZ -->
        <Border Grid.Row="0" Background="#000000" CornerRadius="6" Padding="12" Margin="4">
            <StackPanel>
                <!-- mały podgląd działania w buforze, np. "7 + 2" -->
                <TextBlock x:Name="ExpressionText" Text="" FontSize="14"
                           Foreground="#888888" HorizontalAlignment="Right" />
                <!-- główny wynik / wpisywana liczba -->
                <TextBlock x:Name="ResultText" Text="0" FontSize="40" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <!-- KLAWIATURA: 6 wierszy x 4 kolumny -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Wiersz 0: funkcje -->
            <Button Grid.Row="0" Grid.Column="0" Content="C" Click="Clear_Click" Background="#A52A2A" />
            <Button Grid.Row="0" Grid.Column="1" Content="√" Click="Sqrt_Click" />
            <Button Grid.Row="0" Grid.Column="2" Content="1/x" Click="Reciprocal_Click" />
            <Button Grid.Row="0" Grid.Column="3" Content="xʸ" Click="Power_Click" Style="{StaticResource OpButton}" />

            <!-- Wiersz 1 -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Click="Digit_Click" />
            <Button Grid.Row="1" Grid.Column="1" Content="8" Click="Digit_Click" />
            <Button Grid.Row="1" Grid.Column="2" Content="9" Click="Digit_Click" />
            <Button Grid.Row="1" Grid.Column="3" Content="÷" Click="Divide_Click" Style="{StaticResource OpButton}" />

            <!-- Wiersz 2 -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Click="Digit_Click" />
            <Button Grid.Row="2" Grid.Column="1" Content="5" Click="Digit_Click" />
            <Button Grid.Row="2" Grid.Column="2" Content="6" Click="Digit_Click" />
            <Button Grid.Row="2" Grid.Column="3" Content="×" Click="Multiply_Click" Style="{StaticResource OpButton}" />

            <!-- Wiersz 3 -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="1" Content="2" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="2" Content="3" Click="Digit_Click" />
            <Button Grid.Row="3" Grid.Column="3" Content="−" Click="Subtract_Click" Style="{StaticResource OpButton}" />

            <!-- Wiersz 4 -->
            <Button Grid.Row="4" Grid.Column="0" Content="0" Click="Digit_Click" />
            <Button Grid.Row="4" Grid.Column="1" Content="," Click="Decimal_Click" />
            <Button Grid.Row="4" Grid.Column="2" Content="%" Click="Percent_Click" />
            <Button Grid.Row="4" Grid.Column="3" Content="+" Click="Add_Click" Style="{StaticResource OpButton}" />

            <!-- Wiersz 5: równa się (na całą szerokość) -->
            <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Content="="
                    Click="Equals_Click" Background="#2E7D32" />
        </Grid>
    </Grid>
</Window>
